#!/bin/bash
# Nemesis AI Coordination Hook — auto-updates NEMESIS.md after every commit.
# This means whatever AI commits gets logged automatically. No discipline required.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
SYNC_FILE="$REPO_ROOT/NEMESIS.md"

if [ ! -f "$SYNC_FILE" ]; then
    exit 0
fi

# Re-entry guard: skip if this commit is itself a log entry (prevents infinite loop)
if git log -1 --pretty=%B | grep -q "^chore: auto-log NEMESIS.md$"; then
    exit 0
fi

# Get commit info
HASH=$(git rev-parse --short HEAD)
SUBJECT=$(git log -1 --pretty=%s)
DATE=$(git log -1 --pretty=%cd --date=short)
BODY=$(git log -1 --pretty=%b)

# Extract AI identity from Co-Authored-By trailer (must end with <email@addr>)
# Only match the actual trailer format, not loose mentions in commit body
AI=$(echo "$BODY" | grep -iE '^Co-Authored-By:[[:space:]]+.+<[^>]+>[[:space:]]*$' | head -1 | sed -E 's/^Co-Authored-By:[[:space:]]+(.+)[[:space:]]+<[^>]+>[[:space:]]*$/\1/' | xargs)
if [ -z "$AI" ]; then
    AUTHOR=$(git log -1 --pretty=%an)
    AI="Manual ($AUTHOR)"
fi

# Update "Last commit" + "Last AI" + "Date" in CURRENT STATE
TMP=$(mktemp)
awk -v hash="$HASH" -v subject="$SUBJECT" -v ai="$AI" -v date="$DATE" '
    /^\*\*Last commit:\*\*/ { print "**Last commit:** `" hash "` — " subject; next }
    /^\*\*Last AI to touch this:\*\*/ { print "**Last AI to touch this:** " ai; next }
    /^\*\*Date:\*\* / && !date_done { print "**Date:** " date; date_done=1; next }
    { print }
' "$SYNC_FILE" > "$TMP" && mv "$TMP" "$SYNC_FILE"

# Prepend a new line to the AI Coordination Log
LOG_ENTRY="- **[$DATE]** $AI: $SUBJECT (\`$HASH\`)"

awk -v entry="$LOG_ENTRY" '
    /^> \*Each AI logs ONE LINE/ {
        print
        getline
        print
        print ""
        print entry
        next
    }
    { print }
' "$SYNC_FILE" > "$TMP" && mv "$TMP" "$SYNC_FILE"

# Auto-commit the NEMESIS.md log update so the working tree stays clean.
# Uses a sentinel commit message that the re-entry guard above filters out.
if ! git diff --quiet NEMESIS.md; then
    git add NEMESIS.md
    git -c commit.gpgsign=false commit -m "chore: auto-log NEMESIS.md" --no-verify >/dev/null
    echo "[Nemesis] NEMESIS.md auto-logged ($HASH → $(git rev-parse --short HEAD))"
else
    echo "[Nemesis] NEMESIS.md no changes (commit $HASH)"
fi
